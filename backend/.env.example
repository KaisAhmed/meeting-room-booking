PORT=3000
CLIENT_ORIGIN=http://localhost:5173

# SQL Server connection string.
# Example (adjust to your instance/database):
# SQL_CONNECTION_STRING="Server=localhost\\SQLEXPRESS;Database=MeetingBooking;User Id=sa;Password=YOUR_PASSWORD;TrustServerCertificate=true;"
SQL_CONNECTION_STRING=

SESSION_SECRET=change-me-to-a-long-random-secret

# If set, backend will create an initial admin user (only if it doesn't already exist).
INIT_ADMIN_USERNAME=admin
INIT_ADMIN_PASSWORD=admin123

# Default room id for booking conflict checks.
ROOM_ID=1

